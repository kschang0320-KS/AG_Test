# 암호화 비밀키 설정
# 이 파일을 .env 로 복사한 후 아래 키를 변경하세요.
# 실제 배포 환경에서는 절대 기본값을 그대로 사용하지 마세요!

# localStorage 암호화 비밀키 (영문+숫자+특수문자 조합 32자 이상 권장)
VITE_STORAGE_KEY=your-super-secret-key-here-change-this

# -----------------------------------------------------------------------------
# [슬랙 알림 연동]
# 신규 익명 의견 등록 시 알림을 받을 Slack Webhook URL (선택)
# -----------------------------------------------------------------------------
VITE_SLACK_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# [관리자 전용 로그인 계정 설정]
# VITE_ADMIN_ID: 관리자 로그인에 사용할 아이디
# VITE_ADMIN_PWD_HASH: 관리자 로그인에 사용할 비밀번호의 SHA-256 해시값 (소문자)
# 기본 예시: admin / admin123 (hash: 240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9)
# -----------------------------------------------------------------------------
VITE_ADMIN_ID=admin
VITE_ADMIN_PWD_HASH=240be518fabd2724ddb6f04eeb1da5967448d7e831c08c8fa822809f74c720a9
